# Kopiere nach .env:  cp .env.example .env

# Active Directory
REALM=ad.orv.space
DOMAIN=AD
ADMIN_PASSWORD=ChangeMe_SecurePassword123!
DC_HOSTNAME=dc01

# Netzwerk (LAN 192.168.100.0/24)
DC_IP=192.168.100.10
DOCKER_HOST_IP=192.168.100.154
HOST_SHIM_IP=192.168.100.155
GATEWAY=192.168.100.245
SUBNET=192.168.100.0/24
MACVLAN_PARENT=eth0

# DNS (intern autoritativ, externer Forwarder)
DNS_FORWARDER=192.168.100.170

# Lokales Image (wird auf dem Pi gebaut)
SAMBA_AD_IMAGE=samba-ad-orv:bookworm-arm64

# Phase 2 (später): DHCP_RANGE_START, DHCP_RANGE_END, Watchtower

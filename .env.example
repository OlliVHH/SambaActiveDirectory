# Kopiere nach .env und passe Werte an:
#   cp .env.example .env

# Active Directory
REALM=ad.orv.space
DOMAIN=AD
ADMIN_PASSWORD=ChangeMe_SecurePassword123!
DC_HOSTNAME=dc01

# Netzwerk (LAN 192.168.100.0/24)
DC_IP=192.168.100.10
DOCKER_HOST_IP=192.168.100.154
HOST_SHIM_IP=192.168.100.155
GATEWAY=192.168.100.245
SUBNET=192.168.100.0/24
MACVLAN_PARENT=eth0

# DNS & DHCP
DNS_FORWARDER=192.168.100.170
DHCP_RANGE_START=192.168.100.60
DHCP_RANGE_END=192.168.100.79
DHCP_LEASE_TIME=86400

# Docker Images
# Raspberry Pi (ARM64): :arm64  |  x86-Server: :amd64 oder :4.24.3
# :latest ist Multi-Arch, aber für Pi explizit :arm64 empfohlen (Watchtower-Pinning)
SAMBA_AD_IMAGE=diegogslomp/samba-ad-dc:arm64
WATCHTOWER_IMAGE=containrrr/watchtower:latest

# Watchtower: Sonntag 04:00 Uhr (Werte mit Leerzeichen müssen in Anführungszeichen stehen)
WATCHTOWER_SCHEDULE="0 4 * * 0"
